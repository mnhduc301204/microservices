# Shared local defaults for running services outside Aspire.
# Do not put real secrets in this file.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

InternalApi__RequireInbound=true
InternalApi__ApiKey=replace-with-local-internal-api-key

Kafka__BootstrapServers=localhost:9092

ConnectionStrings__catalogdb=Host=localhost;Port=5432;Database=catalogdb;Username=postgres;Password=postgres
ConnectionStrings__inventorydb=Host=localhost;Port=5432;Database=inventorydb;Username=postgres;Password=postgres
ConnectionStrings__orderingdb=Host=localhost;Port=5432;Database=orderingdb;Username=postgres;Password=postgres
ConnectionStrings__paymentdb=Host=localhost;Port=5432;Database=paymentdb;Username=postgres;Password=postgres
ConnectionStrings__notificationdb=Host=localhost;Port=5432;Database=notificationdb;Username=postgres;Password=postgres
ConnectionStrings__basket-redis=localhost:6379

Authentication__Issuer=ecommerce-dev
Authentication__Audience=ecommerce-api
Authentication__SigningKey=replace-with-at-least-32-characters

PaymentProvider__WebhookSecret=replace-with-payment-webhook-secret
PaymentProvider__FakeAlwaysSucceed=true
PaymentProvider__FakeProcessingDelaySeconds=2

Swagger__Enabled=true
