ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:7000

Authentication__Issuer=ecommerce-dev
Authentication__Audience=ecommerce-api
Authentication__SigningKey=replace-with-at-least-32-characters

InternalApi__RequireInbound=false
InternalApi__ApiKey=replace-with-local-internal-api-key

Swagger__Enabled=true
